# ─────────────────────────────────────────────────────────────
# API Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pos4

# ── Auth (Clerk) ──────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Redis (BullMQ queues) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── AI Agent ─────────────────────────────────────────────────
# OpenAI (recommended for production — use gpt-4o-mini)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama fallback (used if OPENAI_API_KEY is not set)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ── WhatsApp Business (Meta Cloud API) ───────────────────────
# Get these from https://developers.facebook.com/apps
WHATSAPP_ACCESS_TOKEN=           # Meta permanent token or system user token
WHATSAPP_PHONE_NUMBER_ID=        # Phone number ID from Meta dashboard
WHATSAPP_WEBHOOK_VERIFY_TOKEN=   # Any random string you define for webhook verification
# Example: WHATSAPP_WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token_123

# ── Stripe (Billing) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App Config ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
