# ─────────────────────────────────────────────────────────────
# POS SaaS — Environment Variables Template
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://pos_user:pos_password@localhost:5432/pos_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Clerk Authentication ──────────────────────────────────────
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# ── Clerk URLs (Next.js App) ─────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Stripe Billing ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_BASIC=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx

# ── API URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000

# ── App URLs (for CORS) ──────────────────────────────────────
# Replace [DOMINIO] with your actual domain
APP_URL=http://localhost:3000
MARKETING_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Node Environment ─────────────────────────────────────────
NODE_ENV=development
